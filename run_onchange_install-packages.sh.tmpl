#!/usr/bin/env bash
# Installs Tony's dev toolset. Re-runs only when this script's rendered content
# changes (chezmoi run_onchange) — the embedded hashes below force that when the
# package lists change.
set -euo pipefail

# tmux plugin manager — cloned to the XDG path so tpm + its plugins are co-located.
TPM_DIR="$HOME/.config/tmux/plugins/tpm"
[ -d "$TPM_DIR" ] || git clone --depth 1 https://github.com/tmux-plugins/tpm "$TPM_DIR"

{{ if eq .chezmoi.os "darwin" -}}
# Brewfile hash: {{ include "Brewfile" | sha256sum }}
echo ">> brew bundle (macOS)"
brew bundle --file="{{ .chezmoi.sourceDir }}/Brewfile"
# per-machine extra packages (not in this repo), if present
[ -f "$HOME/.Brewfile.local" ] && brew bundle --file="$HOME/.Brewfile.local"

{{ else if eq .chezmoi.os "linux" -}}
# linux package set hash: 2026-07-06-a
# Everything installs into ~/.local (no sudo). Downloads go to a file then extract —
# no piping remote scripts to a shell.
echo ">> installing dev tools (Linux, no sudo — user space)"
mkdir -p "$HOME/.local/bin" "$HOME/.local/opt"

# Rust CLI tools via cargo-binstall (prebuilt binaries from crates.io/GitHub)
command -v cargo-binstall >/dev/null 2>&1 || cargo install cargo-binstall
cargo binstall -y ripgrep fd-find bat eza git-delta difftastic zoxide atuin

# Node (pinned LTS static tarball) — needed by pyright + hunk. Skip if node >= 18 exists.
if [ "$(node -v 2>/dev/null | sed 's/v//;s/\..*//' || echo 0)" -lt 18 ]; then
  NODE_VER=v22.11.0
  curl -fsSL -o "$HOME/.local/opt/node.tar.xz" "https://nodejs.org/dist/${NODE_VER}/node-${NODE_VER}-linux-x64.tar.xz"
  tar -xJf "$HOME/.local/opt/node.tar.xz" -C "$HOME/.local/opt" && rm -f "$HOME/.local/opt/node.tar.xz"
  ln -sf "$HOME/.local/opt/node-${NODE_VER}-linux-x64/bin/"{node,npm,npx} "$HOME/.local/bin/"
fi

# npm globals: Bitwarden CLI (secrets) + hunk (review TUI)
npm i -g @bitwarden/cli hunkdiff 2>/dev/null || true

# Neovim static tarball — kickstart needs >= 0.9. Install/upgrade if missing/old.
if ! nvim --version 2>/dev/null | head -1 | grep -qE 'v(0\.(9|[1-9][0-9])|[1-9])'; then
  curl -fsSL -o "$HOME/.local/opt/nvim.tar.gz" https://github.com/neovim/neovim/releases/latest/download/nvim-linux-x86_64.tar.gz
  tar -xzf "$HOME/.local/opt/nvim.tar.gz" -C "$HOME/.local/opt" && rm -f "$HOME/.local/opt/nvim.tar.gz"
  ln -sf "$HOME/.local/opt/nvim-linux-x86_64/bin/nvim" "$HOME/.local/bin/nvim"
fi

# tmux (static AppImage, extracted) — >= 3.3 for allow-passthrough. Install if missing/old.
if ! tmux -V 2>/dev/null | grep -qE '3\.[3-9]|[4-9]'; then
  ( cd "$HOME/.local/opt" \
    && curl -fsSL -o tmux.appimage https://github.com/nelsonenzo/tmux-appimage/releases/download/3.5a/tmux.appimage \
    && chmod +x tmux.appimage && ./tmux.appimage --appimage-extract >/dev/null \
    && rm -f tmux.appimage && rm -rf tmux-appimage && mv squashfs-root tmux-appimage )
  printf '#!/usr/bin/env bash\nexec "$HOME/.local/opt/tmux-appimage/AppRun" "$@"\n' > "$HOME/.local/bin/tmux"
  chmod +x "$HOME/.local/bin/tmux"
fi
# (lazygit / tig / gh not auto-installed on Linux yet — add release tarballs if wanted.)
{{ end -}}
